# ============================================
# PERSONAL CHEF — VARIÁVEIS DE AMBIENTE
# ============================================
# Copia este ficheiro para .env e preenche com os teus dados reais.
# NUNCA commites o ficheiro .env — está no .gitignore.
# ============================================

# --------------------------------------------
# EVOLUTION API (WhatsApp)
# --------------------------------------------
EVOLUTION_API_URL=https://your-server.railway.app
EVOLUTION_API_KEY=your_evolution_api_key_here
WHATSAPP_INSTANCE=your_instance_name_here

# --------------------------------------------
# GOOGLE GEMINI AI
# --------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
# Obter em: https://aistudio.google.com/app/apikey

# --------------------------------------------
# GOOGLE SHEETS
# --------------------------------------------
GOOGLE_SHEET_ID=your_google_sheet_id_here
# O ID está no URL do Google Sheets:
# https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit

GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----"

# --------------------------------------------
# GOOGLE FORMS
# --------------------------------------------
GOOGLE_FORM_ID=your_google_form_id_here

# --------------------------------------------
# MAKE.COM
# --------------------------------------------
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your_webhook_id_here

# --------------------------------------------
# N8N
# --------------------------------------------
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.railway.app
N8N_API_KEY=your_n8n_api_key_here

# --------------------------------------------
# CONFIGURAÇÕES DO AGENTE IA
# --------------------------------------------
# Idiomas suportados pelo agente (não alterar)
AGENT_LANGUAGES=pt,en,es

# Timeout de sessão em minutos
SESSION_TIMEOUT_MINUTES=30
